# ==========================================
#  COLORED LS AND GREP
# ==========================================
# Enable colors, group directories first, and add file type indicators
alias ls='ls --color=auto --group-directories-first -F'
alias grep='grep --color=auto --exclude-dir={.git,node_modules,venv}'

# ==========================================
#  DIRECTORY LISTINGS & NAVIGATION
# ==========================================
alias ll='ls -lhrt'       # Long format, human-readable, reverse time sort
alias la='ls -A'          # Show hidden files (except . and ..)
alias ..='cd ..'
alias ...='cd ../..'

# ==========================================
#  SYSTEM UTILITIES (Human Readable)
# ==========================================
alias df='df -h'
alias du='du -h'
alias free='free -m'      # Show memory in MB

# ==========================================
#  IP ADDRESSES (Interface Agnostic)
# ==========================================
# Public IP using a simple curl
alias publicip='curl -s https://ifconfig.me'
alias publicip6='dig +short -6 myip.opendns.com AAAA @resolver1.ipv6-sandbox.opendns.com'

# Private IP: Grabs the primary internal IP regardless of interface name (eth0/wlan0/enp)
alias privateip="hostname -I | awk '{print \$1}'"

# ==========================================
#  DOTFILES MANAGEMENT
# ==========================================
# Downloads tarball, strips components, and restarts the shell session
alias update_dotfiles='cd ~ && curl -Lk# https://github.com/hassanalsaffar/DotFiles/tarball/master | tar --strip-components 1 -xz && exec $SHELL'

# ==========================================
#  SAFETY NETS
# ==========================================
alias cp='cp -i'
alias mv='mv -i'
alias rm='rm -i'
